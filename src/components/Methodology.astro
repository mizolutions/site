---
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].method;
---

<section class="section method" id="method">
  <div class="container method__inner">
    <div class="method__intro">
      <p class="kicker">{t.kicker}</p>
      <h2>{t.title}</h2>
      <p class="lead">{t.body}</p>
    </div>
    <ul class="method__principles">
      {
        t.principles.map((p) => (
          <li>
            <h3 class="method__principle-title">{p.title}</h3>
            <p class="muted">{p.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .method__inner {
    display: grid;
    gap: clamp(1.75rem, 1rem + 3vw, 3.5rem);
    grid-template-columns: 1fr;
  }
  .method__intro h2 {
    margin-block: 0.6rem 1rem;
    max-width: 16ch;
  }
  .method__principles {
    display: grid;
    gap: 1.25rem;
  }
  .method__principle-title {
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--accent);
    margin-bottom: 0.3rem;
  }
  .method__principles li {
    border-left: 1px solid var(--border-strong);
    padding-left: 1.1rem;
    max-width: 56ch;
  }
  @media (min-width: 860px) {
    .method__inner {
      grid-template-columns: 1.1fr 1fr;
      align-items: start;
    }
  }
</style>
