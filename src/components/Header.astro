---
import { SITE, CONTACT_HREF } from '../consts';
import { ui, localizeUrl, type Lang } from '../i18n/ui';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].nav;
const home = localizeUrl('/', lang);
const blog = localizeUrl('/blog', lang);

const nav = [
  { href: `${home}#services`, label: t.services },
  { href: `${home}#case`, label: t.case },
  { href: `${home}#method`, label: t.method },
  { href: blog, label: t.writing },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="logo" href={home} aria-label={SITE.brand}>
      <span>mizolutions</span><span class="logo__caret" aria-hidden="true">_</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
    </nav>

    <div class="site-header__right">
      <LangSwitch lang={lang} />
      <a class="btn btn--ghost site-header__cta" href={CONTACT_HREF}>{t.contact}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 4rem;
  }
  .logo {
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: var(--step-0);
    flex: none;
  }
  .logo:hover {
    text-decoration: none;
  }
  .logo__caret {
    color: var(--accent);
  }
  .site-nav {
    display: flex;
    gap: 1.25rem;
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .site-nav a {
    color: var(--text-muted);
  }
  .site-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .site-header__right {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  @media (max-width: 820px) {
    .site-nav {
      display: none;
    }
    .site-header__right {
      margin-left: auto;
    }
    .site-header__cta {
      display: none;
    }
  }
</style>
