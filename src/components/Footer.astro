---
import { SITE, SOCIALS } from '../consts';
import { ui, localizeUrl, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].footer;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a class="logo" href={localizeUrl('/', lang)}>
        <span>mizolutions</span><span class="logo__caret" aria-hidden="true">_</span>
      </a>
      <p class="muted">{t.tagline}</p>
    </div>
    <nav class="site-footer__socials" aria-label="Social">
      {SOCIALS.map((s) => <a href={s.href} rel="me noopener">{s.label}</a>)}
    </nav>
  </div>
  <div class="container site-footer__legal">
    <span class="muted">© {year} {SITE.brand}. {t.rights}</span>
    <span class="site-footer__built">{t.builtWith}</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding-block: clamp(2.5rem, 1.5rem + 4vw, 4rem) 2rem;
    margin-top: var(--section-y);
  }
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    justify-content: space-between;
    align-items: start;
  }
  .site-footer__brand {
    display: grid;
    gap: 0.4rem;
    max-width: 32ch;
  }
  .logo {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--step-0);
  }
  .logo:hover {
    text-decoration: none;
  }
  .logo__caret {
    color: var(--accent);
  }
  .site-footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .site-footer__socials a {
    color: var(--text-muted);
  }
  .site-footer__socials a:hover {
    color: var(--accent);
  }
  .site-footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: var(--step--2);
  }
  .site-footer__built {
    color: var(--text-faint);
  }
</style>
