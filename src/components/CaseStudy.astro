---
import { ui, localizeUrl, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].caseStudy;
const caseUrl = localizeUrl('/trinitrade', lang);
---

<section class="section case" id="case">
  <div class="container">
    <p class="kicker">{t.kicker}</p>
    <h2 class="case__title">{t.title}</h2>
    <p class="lead case__body">{t.body}</p>

    <div class="case__figures">
      <figure class="frame">
        <div class="frame__bar" aria-hidden="true">
          <span></span><span></span><span></span>
          <em class="frame__tag">grafana</em>
        </div>
        <div class="frame__body" role="img" aria-label={t.captionGrafana}>
          <svg viewBox="0 0 320 150" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="g-area" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0" stop-color="var(--accent)" stop-opacity="0.28"></stop>
                <stop offset="1" stop-color="var(--accent)" stop-opacity="0"></stop>
              </linearGradient>
            </defs>
            <polyline
              points="0,118 28,104 56,112 84,80 112,92 140,64 168,78 196,52 224,70 252,44 280,58 320,48"
              fill="none"
              stroke="var(--accent)"
              stroke-width="2"
            ></polyline>
            <polygon
              points="0,150 0,118 28,104 56,112 84,80 112,92 140,64 168,78 196,52 224,70 252,44 280,58 320,48 320,150"
              fill="url(#g-area)"
            ></polygon>
            <rect x="10" y="12" width="74" height="12" rx="3" fill="var(--surface-2)"></rect>
          </svg>
        </div>
        <figcaption>{t.captionGrafana}</figcaption>
      </figure>

      <figure class="frame">
        <div class="frame__bar" aria-hidden="true">
          <span></span><span></span><span></span>
          <em class="frame__tag">cloudwatch</em>
        </div>
        <div class="frame__body" role="img" aria-label={t.captionCloudwatch}>
          <svg viewBox="0 0 320 150" preserveAspectRatio="none" aria-hidden="true">
            <line
              x1="0"
              y1="46"
              x2="320"
              y2="46"
              stroke="var(--danger)"
              stroke-width="1.5"
              stroke-dasharray="6 5"
              opacity="0.7"></line>
            <polyline
              points="0,110 40,106 80,112 120,104 160,108 200,102 240,109 280,105 320,108"
              fill="none"
              stroke="var(--accent)"
              stroke-width="2"></polyline>
            <rect x="10" y="12" width="58" height="12" rx="3" fill="var(--surface-2)"></rect>
          </svg>
          <span class="frame__pill" aria-hidden="true">OK</span>
        </div>
        <figcaption>{t.captionCloudwatch}</figcaption>
      </figure>
    </div>

    <ul class="case__metrics">
      {
        t.metrics.map((m) => (
          <li>
            <span class="case__metric-value">{m.value}</span>
            <span class="case__metric-label muted">{m.label}</span>
          </li>
        ))
      }
    </ul>

    <p class="case__note eyebrow">{t.note}</p>
    <a class="btn btn--ghost" href={caseUrl}>{t.cta}</a>
  </div>
</section>

<style>
  .case__title {
    max-width: 24ch;
    margin-block: 0.6rem 1rem;
  }
  .case__body {
    max-width: 68ch;
  }
  .case__figures {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    margin-block: clamp(1.75rem, 1rem + 3vw, 3rem);
  }
  .frame {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    overflow: hidden;
  }
  .frame__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .frame__bar > span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-strong);
  }
  .frame__tag {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-style: normal;
    color: var(--text-faint);
  }
  .frame__body {
    position: relative;
    height: 150px;
  }
  .frame__body svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .frame__pill {
    position: absolute;
    top: 12px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
    border-radius: var(--radius-pill);
    padding: 0.15rem 0.55rem;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .frame figcaption {
    padding: 0.7rem 0.9rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
  }
  .case__metrics {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
    margin-block: 1.5rem;
    padding: 0;
  }
  .case__metrics li {
    display: grid;
    gap: 0.25rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
  }
  .case__metric-value {
    font-family: var(--font-mono);
    font-size: var(--step-2);
    color: var(--accent);
    font-weight: 600;
  }
  .case__metric-label {
    font-size: var(--step--1);
  }
  .case__note {
    display: block;
    max-width: 60ch;
    margin-bottom: 1.5rem;
  }
</style>
