---
import Base from './Base.astro';
import { localizeUrl, type Lang } from '../i18n/ui';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    kicker?: string;
    lang?: Lang;
    backLabel?: string;
  };
}

const { frontmatter } = Astro.props;
const lang: Lang = frontmatter.lang ?? 'en';
const home = localizeUrl('/', lang);
const back = frontmatter.backLabel ?? (lang === 'es' ? '← Inicio' : '← Home');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: frontmatter.title,
  description: frontmatter.description,
  inLanguage: lang,
  author: { '@type': 'Person', name: 'Misael Tenorio', url: 'https://mizolutions.com/misael' },
  publisher: { '@type': 'Organization', name: 'Mizolutions', url: 'https://mizolutions.com' },
  about: [
    'Site Reliability Engineering',
    'DevOps',
    'AWS',
    'Algorithmic trading systems',
    'Quantitative research',
    'Observability',
    'Infrastructure as Code',
  ],
};
---

<Base
  lang={lang}
  title={`${frontmatter.title} — Mizolutions`}
  description={frontmatter.description}
  jsonLd={jsonLd}
>
  <article class="container case-doc">
    <a class="case-doc__back" href={home}>{back}</a>
    {frontmatter.kicker && <p class="kicker">{frontmatter.kicker}</p>}
    <h1 class="case-doc__title">{frontmatter.title}</h1>
    <p class="lead case-doc__desc">{frontmatter.description}</p>
    <div class="prose case-doc__body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .case-doc {
    padding-block: clamp(2.5rem, 1.5rem + 4vw, 5rem);
  }
  .case-doc__back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .case-doc__back:hover {
    color: var(--accent);
  }
  .case-doc__title {
    margin-block: 0.6rem 1rem;
    max-width: 26ch;
  }
  .case-doc__desc {
    max-width: 72ch;
  }
  .case-doc__body {
    margin-top: clamp(2rem, 1rem + 3vw, 3rem);
    /* Wider than the default blog measure: tables and screenshots need room. */
    max-width: 78ch;
  }

  /* Markdown-rendered content lives in :global scope. */
  .case-doc__body :global(figure) {
    margin-block: 2rem;
  }
  .case-doc__body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .case-doc__body :global(figcaption) {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    text-align: center;
  }
  .case-doc__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: 1.5rem;
    font-size: var(--step--1);
  }
  .case-doc__body :global(th),
  .case-doc__body :global(td) {
    text-align: left;
    vertical-align: top;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--border);
  }
  .case-doc__body :global(th) {
    background: var(--surface);
    font-weight: 600;
  }
  .case-doc__body :global(td:first-child) {
    white-space: nowrap;
    font-weight: 600;
  }
  .case-doc__body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
  }
  /* Table of contents */
  .case-doc__body :global(.toc) {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.1rem 1.4rem 1.2rem;
    margin-block: 2rem;
  }
  .case-doc__body :global(.toc) :global(p) {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .case-doc__body :global(.toc) :global(ol) {
    margin: 0;
    padding-left: 1.2rem;
  }
  .case-doc__body :global(.toc) :global(li) {
    margin-top: 0.25rem;
  }
  /* Per-section "On GitHub" reference lines */
  .case-doc__body :global(.repo-refs) {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    border-left: 2px solid var(--accent-dim);
    padding-left: 0.9rem;
    margin-block: 1.4rem;
    line-height: 1.7;
  }
  .case-doc__body :global(.repo-refs) :global(code) {
    color: var(--text);
  }
  /* Let wide tables scroll on small screens instead of overflowing. */
  @media (max-width: 720px) {
    .case-doc__body :global(table) {
      display: block;
      overflow-x: auto;
    }
    .case-doc__body :global(td:first-child) {
      white-space: normal;
    }
  }
</style>
